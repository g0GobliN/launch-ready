# Supabase — public, safe for client bundle
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase — server-only (write access)
# Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# GitHub OAuth App
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Authorization callback URL: http://localhost:5173/api/auth/callback (dev)
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>

# Session encryption key — generate with: openssl rand -hex 32
# Must be at least 32 characters
SESSION_SECRET=<at-least-32-random-chars>

# Your app's public URL (no trailing slash)
# Development: http://localhost:5173
# Production: https://your-domain.com
APP_URL=http://localhost:5174

# AI — set at least one. Anthropic takes priority if both are set.
# Anthropic: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Stripe
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_<your-secret-key>
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-publishable-key>
