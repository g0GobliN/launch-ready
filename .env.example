# Supabase — public, safe for client bundle
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase — server-only (write access)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# GitHub OAuth App (also used by Supabase GitHub provider)
# Supabase callback: https://<project-id>.supabase.co/auth/v1/callback
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>

# Session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=<at-least-32-random-chars>

# Public app URL (no trailing slash)
APP_URL=https://launchreadyy.xyz

# Admin access (comma-separated GitHub logins)
ADMIN_GITHUB_LOGIN=<your-github-login>
VITE_ADMIN_GITHUB_LOGIN=<your-github-login>

# Stripe
STRIPE_SECRET_KEY=sk_test_<your-secret-key>
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-publishable-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>
STRIPE_PRICE_STARTER=price_<starter-price-id>
STRIPE_PRICE_PRO=price_<pro-price-id>
STRIPE_PRICE_AGENCY=price_<agency-price-id>

# Email (Resend)
RESEND_API_KEY=re_<your-resend-api-key>
RESEND_FROM_EMAIL=hello@launchreadyy.xyz
EMAIL_UNSUBSCRIBE_SECRET=<generate-with: openssl rand -hex 32>
UNSUBSCRIBE_BASE_URL=https://launchreadyy.xyz

# AI — set AI_PROVIDER to one of: deepseek, claude, openai, gemini, cursor
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_API_KEY=sk-ant-...  # alias for ANTHROPIC_API_KEY
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
CURSOR_API_KEY=crsr_...
# CURSOR_MODEL=composer-2.5
# When AI_PROVIDER=cursor, test generation still uses DEEPSEEK_API_KEY (chat API, <3 min).
# Admin margin estimate ($ per AI credit consumed)
AI_COST_PER_CREDIT=0.25
